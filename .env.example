# EngiSuite Analytics Node.js Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=development
PORT=8000
APP_NAME=EngiSuite Analytics
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:8000
FILE_DATA_MODE=false

# ===========================================
# Database Configuration
# ===========================================
# Set FILE_DATA_MODE=true to run with TS/JSON local data only.
# MySQL Connection String (for production/shared hosting)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://u449943183_engisuite:YOUR_PASSWORD@localhost:3306/u449943183_engisuite"

# For local development with SQLite (optional - requires better-sqlite3 native module)
# DATABASE_URL="file:./data/engisuite.db"

# ===========================================
# Authentication Settings
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session settings
SESSION_SECRET=your-session-secret-change-in-production

# ===========================================
# OAuth Configuration
# ===========================================
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# Telegram OAuth
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ===========================================
# Email Configuration (Nodemailer)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@engisuite.com

# ===========================================
# Payment Configuration
# ===========================================
# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Paymob (Egypt)
PAYMOB_API_KEY=your-paymob-api-key
PAYMOB_INTEGRATION_ID=your-integration-id
PAYMOB_IFRAME_ID=your-iframe-id
PAYMOB_HMAC_SECRET=your-hmac-secret

# ===========================================
# AI Services Configuration
# ===========================================
# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Qwen (Alibaba)
QWEN_API_KEY=your-qwen-api-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Together AI
TOGETHER_API_KEY=your-together-api-key
TOGETHER_BASE_URL=https://api.together.xyz/v1

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CORS Configuration
# ===========================================
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000

# ===========================================
# File Upload Configuration
# ===========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# ===========================================
# Hostinger Deployment
# ===========================================
HOSTINGER_API_KEY=your-hostinger-api-key
HOSTINGER_DOMAIN=your-domain.com
